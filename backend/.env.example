# --- Secrets ---
SECRET_KEY=change-me-random-32-chars
JWT_SECRET=change-me-random-32-chars

# --- Environment ---
# "development" or "production"
ENV=development

# --- Database (MySQL / MariaDB) ---
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your-db-password
DB_NAME=nexory

# --- Mail (Resend) ---
MAIL_PASSWORD=re_your_api_key
MAIL_FROM=noreply@yourdomain.com
MAIL_TEMPLATE_VERIFY=tmpl_xxxxxx
MAIL_TEMPLATE_RESET=tmpl_yyyyyy

# --- URLs ---
# Public URL of the frontend (no trailing slash)
FRONTEND_URL=http://localhost:3000

# --- GitHub (optional) ---
GITHUB_TOKEN=your-github-personal-access-token
